<?xml version="1.0"?>
<ruleset name="VeloAuth PMD Ruleset"
         xmlns="http://pmd.sourceforge.net/ruleset/2.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://pmd.sourceforge.net/ruleset/2.0.0 https://pmd.sourceforge.io/ruleset_2_0_0.xsd">

    <description>
        PMD ruleset for VeloAuth plugin - focuses on code quality, best practices, and performance.
        Excludes overly strict rules that conflict with SonarQube or project standards.
    </description>

    <!-- Best Practices -->
    <rule ref="category/java/bestpractices.xml">
        <!-- Exclude rules that conflict with Mockito/JUnit patterns -->
        <exclude name="JUnitTestContainsTooManyAsserts"/>
        <exclude name="JUnitAssertionsShouldIncludeMessage"/>
        <exclude name="JUnitTestsShouldIncludeAssert"/>
        <!-- SLF4J parameterized logging does not need log-level guards -->
        <exclude name="GuardLogStatement"/>
        <!-- LooseCoupling: ConcurrentHashMap used intentionally for atomic operations -->
        <exclude name="LooseCoupling"/>
        <!-- UseVarargs: API design choice, not always appropriate -->
        <exclude name="UseVarargs"/>
    </rule>

    <!-- Code Style -->
    <rule ref="category/java/codestyle.xml">
        <!-- Exclude overly strict naming rules -->
        <exclude name="LongVariable"/>
        <exclude name="ShortVariable"/>
        <exclude name="ShortMethodName"/>
        <exclude name="ShortClassName"/>
        <exclude name="OnlyOneReturn"/>
        <exclude name="AtLeastOneConstructor"/>
        <exclude name="CallSuperInConstructor"/>
        <exclude name="CommentDefaultAccessModifier"/>
        <exclude name="LocalVariableCouldBeFinal"/>
        <exclude name="MethodArgumentCouldBeFinal"/>
        <!-- logger naming is standard Java convention -->
        <exclude name="FieldNamingConventions"/>
        <!-- var usage is intentional Java 10+ style -->
        <exclude name="UseExplicitTypes"/>
        <!-- Style preferences — not bugs -->
        <exclude name="ConfusingTernary"/>
        <exclude name="UnnecessaryModifier"/>
        <exclude name="UseUnderscoresInNumericLiterals"/>
        <exclude name="UselessParentheses"/>
        <exclude name="LinguisticNaming"/>
        <exclude name="UnnecessaryFullyQualifiedName"/>
        <exclude name="BooleanGetMethodName"/>
        <!-- Single-line if-return in equals/validation is idiomatic Java -->
        <exclude name="ControlStatementBraces"/>
        <!-- Fields near their usage can be more readable -->
        <exclude name="FieldDeclarationsShouldBeAtStartOfClass"/>
    </rule>

    <!-- Design -->
    <rule ref="category/java/design.xml">
        <!-- Exclude cognitive complexity - already handled by SonarQube -->
        <exclude name="CognitiveComplexity"/>
        <exclude name="CyclomaticComplexity"/>
        <exclude name="NPathComplexity"/>
        <exclude name="ExcessiveImports"/>
        <exclude name="LawOfDemeter"/>
        <exclude name="LoosePackageCoupling"/>
        <exclude name="TooManyMethods"/>
        <exclude name="TooManyFields"/>
        <!-- DTOs and value objects are valid patterns -->
        <exclude name="DataClass"/>
        <exclude name="GodClass"/>
        <!-- Plugin error handling requires catching broad exceptions -->
        <exclude name="AvoidCatchingGenericException"/>
        <!-- Settings class legitimately exposes many public getters -->
        <exclude name="ExcessivePublicCount"/>
        <!-- Main plugin class naturally has many dependencies -->
        <exclude name="CouplingBetweenObjects"/>
        <!-- False positives with pattern matching instanceof -->
        <exclude name="SimplifyBooleanReturns"/>
        <!-- API design choice -->
        <exclude name="UseObjectForClearerAPI"/>
        <!-- Driver loading pattern uses exception for flow -->
        <exclude name="ExceptionAsFlowControl"/>
    </rule>

    <!-- Error Prone -->
    <rule ref="category/java/errorprone.xml">
        <!-- Keep most error-prone rules but exclude false positives -->
        <exclude name="NullAssignment"/>
        <!-- Builder pattern: fields named same as builder methods -->
        <exclude name="AvoidFieldNameMatchingMethodName"/>
        <!-- Validation code legitimately uses literals in conditions -->
        <exclude name="AvoidLiteralsInIfCondition"/>
        <!-- Pattern matching equals - modern Java idiom -->
        <exclude name="UnusedNullCheckInEquals"/>
        <!-- Messages.reload() is effectively final (no subclasses) -->
        <exclude name="ConstructorCallsOverridableMethod"/>
        <!-- Idiomatic while ((x = ...) != null) pattern -->
        <exclude name="AssignmentInOperand"/>
        <!-- Not using Java serialization -->
        <exclude name="MissingSerialVersionUID"/>
        <!-- Context classloader needed for plugin environment -->
        <exclude name="UseProperClassLoader"/>
        <!-- False positives with ORMLite try-finally resource management -->
        <exclude name="CloseResource"/>
        <!-- Minecraft usernames are ASCII-only -->
        <exclude name="UseLocaleWithCaseConversions"/>
    </rule>

    <!-- Multithreading -->
    <rule ref="category/java/multithreading.xml">
        <!-- Virtual threads (Java 21) safe patterns -->
        <exclude name="UseConcurrentHashMap"/> <!-- We use it properly with locks -->
        <exclude name="DoNotUseThreads"/> <!-- We use virtual threads intentionally -->
        <!-- Volatile used intentionally for visibility in concurrent code -->
        <exclude name="AvoidUsingVolatile"/>
    </rule>

    <!-- Performance -->
    <rule ref="category/java/performance.xml">
        <!-- Keep performance rules but exclude overly aggressive ones -->
        <exclude name="AvoidInstantiatingObjectsInLoops"/> <!-- Sometimes necessary -->
        <!-- Micro-optimizations — readability more important -->
        <exclude name="AppendCharacterWithChar"/>
        <exclude name="ConsecutiveAppendsShouldReuse"/>
        <exclude name="InefficientEmptyStringCheck"/>
        <exclude name="UseStringBufferForStringAppends"/>
        <!-- Explicit initialization (e.g., = false, = null) improves readability -->
        <exclude name="RedundantFieldInitializer"/>
    </rule>

    <!-- Security -->
    <rule ref="category/java/security.xml">
        <!-- Keep all security rules - critical for authentication plugin -->
    </rule>

    <!-- Documentation -->
    <rule ref="category/java/documentation.xml">
        <!-- Require JavaDoc only for public APIs -->
        <exclude name="CommentRequired"/>
        <exclude name="CommentSize"/>
        <!-- ORMLite requires no-arg constructors, comment adds no value -->
        <exclude name="UncommentedEmptyConstructor"/>
    </rule>

    <!-- Custom rule priorities for duplicate-prone code -->
    <rule ref="category/java/errorprone.xml/AvoidDuplicateLiterals">
        <properties>
            <property name="skipAnnotations" value="true"/>
            <property name="maxDuplicateLiterals" value="6"/> <!-- Allow up to 6 duplicates -->
        </properties>
    </rule>

</ruleset>
